<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CSharpNeedforSpeed.ViewModels"
        x:Class="CSharpNeedforSpeed.Views.CarSelectionWindow"
        Title="C# Need for Speed - Select Your Car"
        Width="1000" Height="650"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#080e18"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Design.DataContext>
        <vm:CarSelectionViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="40,*,Auto">

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#080e18" Padding="12,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="RACE_SIM_UTILITY_V1"
                           FontSize="13"
                           FontWeight="Black"
                           Foreground="#e9eefd"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20"
                            Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="VEHICLE SELECTION"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#84adff" />
                    <TextBlock Text="TELEMETRY"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#e9eefd"
                               Opacity="0.4" />
                    <TextBlock Text="HARDWARE"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#e9eefd"
                               Opacity="0.4" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="_" Width="28" Height="24"
                            FontSize="12" Background="Transparent" Foreground="#84adff"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" CornerRadius="2" />
                    <Button Content="[ ]" Width="28" Height="24"
                            FontSize="9" Background="Transparent" Foreground="#84adff"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" CornerRadius="2" />
                    <Button Content="X" Width="28" Height="24"
                            Command="{Binding GoBackCommand}"
                            FontSize="11" Background="Transparent" Foreground="#84adff"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" CornerRadius="2" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="300,*" Margin="24,20,24,0">

            <!-- Left Panel: Car Selection List -->
            <StackPanel Grid.Column="0" Spacing="20" Margin="0,0,20,0">
                <!-- Header -->
                <StackPanel Spacing="4">
                    <TextBlock Text="SELECT MACHINE"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#e9eefd" />
                    <TextBlock Text="AVAILABLE CHASSIS UNITS"
                               FontSize="10"
                               FontWeight="Medium"
                               Foreground="#a5abb9" />
                </StackPanel>

                <!-- Car List -->
                <ListBox ItemsSource="{Binding AvailableCars}"
                         SelectedItem="{Binding SelectedCar}"
                         Background="Transparent"
                         Foreground="#e9eefd"
                         Padding="0"
                         BorderThickness="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="CornerRadius" Value="2" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#6c9fff" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#18202d" />
                        </Style>
                        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#6c9fff" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16,14" Background="Transparent">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#e9eefd" />
                                        <TextBlock FontSize="10"
                                                   FontWeight="Medium"
                                                   Foreground="#a5abb9">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}SPEED: {0}KM/H | TANK: {1}L">
                                                    <Binding Path="MaxSpeed" />
                                                    <Binding Path="FuelCapacity" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="#ff716c"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Right Panel: Car Details -->
            <Border Grid.Column="1" Background="#131a26" Padding="30">
                <ScrollViewer>
                    <TextBlock Text="{Binding CarDetails}"
                               FontSize="14"
                               Foreground="#a5abb9"
                               TextWrapping="Wrap"
                               FontFamily="Consolas,Courier New,monospace"
                               LineHeight="24" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#131a26" Padding="24,16">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Build Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="C# NEED FOR SPEED | BUILD 0.4.2-STABLE"
                               FontSize="10"
                               FontWeight="Medium"
                               Foreground="#a5abb9"
                               Opacity="0.6" />
                </StackPanel>
                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <Button Content="BACK"
                            Command="{Binding GoBackCommand}"
                            Width="120" Height="44"
                            FontSize="12"
                            FontWeight="Bold"
                            Background="#3e4758"
                            Foreground="#c7d0e5"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            CornerRadius="4" />
                    <Button Command="{Binding StartRaceCommand}"
                            Width="160" Height="44"
                            Background="#6c9fff"
                            Foreground="#000000"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            CornerRadius="4">
                        <TextBlock Text="START RACE!"
                                   FontSize="12"
                                   FontWeight="Black" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
